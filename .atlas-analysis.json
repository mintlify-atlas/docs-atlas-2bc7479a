  "keyFeatures": [
    "Authoritative server-side game logic for cheat-proof multiplayer",
    "Automatic real-time state synchronization with delta compression and binary encoding",
    "Room-based matchmaking with filtering, queuing, and reconnection support",
    "Horizontal scalability with Redis driver and presence for multi-process deployments",
    "Multi-platform client SDKs: TypeScript, Unity, Godot, GameMaker, Defold, Construct 3, Haxe",
    "Built-in authentication with JWT, OAuth, and email/password support",
    "Multiple transport options: WebSocket (ws), uWebSockets, Bun, TCP",
    "Dev mode with room state persistence and automatic client reconnection on server restart",
    "Built-in rooms: LobbyRoom, RelayRoom, QueueRoom",
    "Monitor dashboard for real-time server inspection"
  ],
  "publicApiSurface": [
    "Server (class) - main server entry point",
    "Room (class) - base class for defining game rooms",
    "room() / defineRoom() - room registration helpers",
    "defineServer() - server factory function",
    "listen() - start server and listen on port",
    "matchMaker - matchmaking API (createRoom, joinOrCreate, findOneRoomAvailable, etc.)",
    "Client (interface) - connected client representation",
    "Transport (abstract class) - pluggable transport layer",
    "LocalPresence / RedisPresence - presence backends",
    "LocalDriver / RedisDriver / MongooseDriver - matchmaker storage drivers",
    "auth() - authentication middleware factory",
    "JWT (class) - JSON Web Token utilities",
    "LobbyRoom / RelayRoom / QueueRoom - built-in room implementations",
    "createEndpoint() / createRouter() - HTTP endpoint definition",
    "ColyseusSDK / Client (client-side) - JS/TS client SDK entry points",
    "Room (client-side class) - client-side room connection",
    "Auth (client-side class) - client-side authentication",
    "validate() - message schema validation helper",
    "Clock / Delayed - server-side timer utilities",
    "ServerError - typed server error class"
  ]
}
